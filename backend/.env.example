# Environment Configuration
NODE_ENV=production
PORT=3091

# Database - Update with your production database credentials
DATABASE_URL=postgresql://username:password@db-host:5432/learning_center

# JWT - Generate a strong random secret for production
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=7d

# Security
BCRYPT_ROUNDS=10

# CORS - Update with your frontend URL
CORS_ORIGIN=http://localhost:3090

# Logging
LOG_LEVEL=info
